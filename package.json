{
  "name": "webhook-delivery-platform",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "db:validate": "cross-env DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/webhook_delivery prisma validate",
    "db:generate": "cross-env DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/webhook_delivery prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "build": "npm run db:generate && npm run build --workspaces --if-present",
    "typecheck": "npm run db:generate && npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "cross-env": "^10.1.0",
    "prisma": "^6.19.3",
    "typescript": "~5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
